@page
@model SynCraft.Pages.Persons.IndexModel
@{
    ViewData["Title"] = "Persons";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Persons</h2>
    <a asp-page="Create" class="btn btn-primary">+ Add Person</a>
</div>

@if (Model.Persons.Count == 0)
{
    <div class="alert alert-info">No persons defined yet. Add one to get started.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th style="width: 150px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var person in Model.Persons)
            {
                <tr>
                    <td>@person.Name</td>
                    <td>@person.Email</td>
                    <td>@person.Role</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@person.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="Delete" asp-route-id="@person.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
