@page "{id:int}"
@model SynCraft.Pages.Persons.EditModel
@{
    ViewData["Title"] = "Edit Person";
}

<h2>Edit Person</h2>

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <input type="hidden" asp-for="Person.Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Person.Name" class="form-label"></label>
                <input asp-for="Person.Name" class="form-control" />
                <span asp-validation-for="Person.Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Person.Email" class="form-label"></label>
                <input asp-for="Person.Email" class="form-control" type="email" />
                <span asp-validation-for="Person.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Person.Role" class="form-label"></label>
                <input asp-for="Person.Role" class="form-control" />
                <span asp-validation-for="Person.Role" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
