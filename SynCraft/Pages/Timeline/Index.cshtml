<!-- Person suggestions datalist -->
<datalist id="personSuggestions">
    @foreach (var person in Model.KnownPersons)
    {
        <option value="@person" />
    }
</datalist>

@section Scripts {
<script>
    // Populate Edit Step modal from data attributes
    document.getElementById('editStepModal')?.addEventListener('show.bs.modal', function (event) {
        var trigger = event.relatedTarget;
        if (!trigger) return;

        var stepId = trigger.getAttribute('data-step-id');
        var name = trigger.getAttribute('data-name');
        var desc = trigger.getAttribute('data-description');
        var assignee = trigger.getAttribute('data-assignee');
        var category = trigger.getAttribute('data-category');
        var start = trigger.getAttribute('data-start');
        var end = trigger.getAttribute('data-end');
        var state = trigger.getAttribute('data-state');

        document.getElementById('editStepId').value = stepId;
        document.getElementById('editStepName').value = name;
        document.getElementById('editStepDescription').value = desc;
        document.getElementById('editStepAssignee').value = assignee;
        document.getElementById('editStepStart').value = start;
        document.getElementById('editStepEnd').value = end;

        // Set select by numeric value
        var catSelect = document.getElementById('editStepCategory');
        for (var i = 0; i < catSelect.options.length; i++) {
            if (i == parseInt(category)) { catSelect.selectedIndex = i; break; }
        }
        var stateSelect = document.getElementById('editStepState');
        for (var i = 0; i < stateSelect.options.length; i++) {
            if (i == parseInt(state)) { stateSelect.selectedIndex = i; break; }
        }

        // Wire delete button in edit modal to open the confirm delete modal
        var deleteBtn = document.getElementById('editStepDeleteBtn');
        deleteBtn.setAttribute('data-delete-id', stepId);
        deleteBtn.setAttribute('data-delete-name', name);
        deleteBtn.onclick = function () {
            // Close edit modal, then open confirm delete modal
            var editModal = bootstrap.Modal.getInstance(document.getElementById('editStepModal'));
            editModal.hide();
            document.getElementById('deleteStepId').value = stepId;
            document.getElementById('deleteStepName').textContent = name;
            var confirmModal = new bootstrap.Modal(document.getElementById('confirmDeleteStepModal'));
            confirmModal.show();
        };
    });

    // Confirm Delete Step modal
    document.getElementById('confirmDeleteStepModal')?.addEventListener('show.bs.modal', function (event) {
        var trigger = event.relatedTarget;
        if (!trigger) return;
        document.getElementById('deleteStepId').value = trigger.getAttribute('data-delete-id');
        document.getElementById('deleteStepName').textContent = trigger.getAttribute('data-delete-name');
    });

    // Populate Edit Milestone modal from data attributes
    document.getElementById('editMilestoneModal')?.addEventListener('show.bs.modal', function (event) {
        var trigger = event.relatedTarget;
        if (!trigger) return;

        var milestoneId = trigger.getAttribute('data-milestone-id');
        var label = trigger.getAttribute('data-label');
        var date = trigger.getAttribute('data-date');
        var color = trigger.getAttribute('data-color');

        document.getElementById('editMilestoneId').value = milestoneId;
        document.getElementById('editMilestoneLabel').value = label;
        document.getElementById('editMilestoneDate').value = date;

        var colorSelect = document.getElementById('editMilestoneColor');
        for (var i = 0; i < colorSelect.options.length; i++) {
            if (colorSelect.options[i].value === color) { colorSelect.selectedIndex = i; break; }
        }

        // Wire delete button in edit modal to open the confirm delete modal
        var deleteBtn = document.getElementById('editMilestoneDeleteBtn');
        deleteBtn.onclick = function () {
            var editModal = bootstrap.Modal.getInstance(document.getElementById('editMilestoneModal'));
            editModal.hide();
            document.getElementById('deleteMilestoneId').value = milestoneId;
            document.getElementById('deleteMilestoneName').textContent = label;
            var confirmModal = new bootstrap.Modal(document.getElementById('confirmDeleteMilestoneModal'));
            confirmModal.show();
        };
    });

    // Confirm Delete Milestone modal
    document.getElementById('confirmDeleteMilestoneModal')?.addEventListener('show.bs.modal', function (event) {
        var trigger = event.relatedTarget;
        if (!trigger) return;
        document.getElementById('deleteMilestoneId').value = trigger.getAttribute('data-delete-id');
        document.getElementById('deleteMilestoneName').textContent = trigger.getAttribute('data-delete-name');
    });
</script>
}
