@page "{id:int}"
@model SynCraft.Pages.Templates.DeleteModel
@{
    ViewData["Title"] = "Delete Template";
}

<h2>Delete Template</h2>

<div class="alert alert-warning">
    Are you sure you want to delete the template <strong>@Model.Template.Name</strong>
    and all its <strong>@Model.Template.Steps.Count</strong> step(s)?
</div>

@if (Model.InstanceCount > 0)
{
    <div class="alert alert-danger">
        ⚠️ There are <strong>@Model.InstanceCount</strong> active process instance(s) using this template.
        Deleting the template will not remove those instances.
    </div>
}

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Template.Name</dd>
    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@(Model.Template.Description ?? "None")</dd>
    <dt class="col-sm-3">Steps</dt>
    <dd class="col-sm-9">@Model.Template.Steps.Count</dd>
</dl>

<form method="post" asp-route-id="@Model.Template.Id">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
</form>
